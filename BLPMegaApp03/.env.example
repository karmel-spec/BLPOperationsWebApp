# Copy these keys into Netlify environment variables.
# Do not commit real secrets or phone numbers other than approved public business numbers.

# Shared passcode required by sales Netlify functions.
BLP_APP_ACCESS_KEY=

# Live Sales Leads sheet sync.
SALES_LEADS_APPS_SCRIPT_URL=
SALES_LEADS_SYNC_SECRET=

# Twilio SMS and call actions.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+18017010113

# Staff phone Twilio calls first, then Twilio bridges to the customer.
SALES_CALL_BRIDGE_NUMBER=

# Existing new-lead alert recipient, if that alert remains enabled.
BRIGHAM_LEAD_ALERT_PHONE=

# Sales email actions.
SENDGRID_API_KEY=
SALES_EMAIL_FROM=brigham@brighamlarsonpianos.com
SALES_EMAIL_BCC=info@brighamlarsonpianos.com
